# Spotify API credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_SECRET_ID=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Last.fm API credentials (https://www.last.fm/api/account/create)
LASTFM_API_KEY=your_lastfm_api_key
LASTFM_SHARED_SECRET=your_lastfm_shared_secret
LASTFM_REDIRECT_URI=http://localhost:8888/callback

# Optional compatibility alias (use either LASTFM_SHARED_SECRET or LASTFM_SECRET)
# LASTFM_SECRET=your_lastfm_shared_secret

# Optional logging/session identifiers
# REQUEST_LOG_GROUP=manual_session_name

# Optional override for local auth token storage file
# AUTH_STORE_PATH=./data/auth/tokens.json
